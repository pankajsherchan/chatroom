# ChatRoom runtime configuration.
# Copy this file to `.env` for local runs.

# Active model provider for chat.
# Options: ollama | openai | bedrock
MODEL_PROVIDER=ollama

# Backend and frontend local wiring.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001
VITE_API_URL=http://127.0.0.1:8001

# Local SQLite path.
SQLITE_DB_PATH=backend/data/chatroom.sqlite3

# OpenAI (when MODEL_PROVIDER=openai).
OPENAI_API_KEY=
OPENAI_MODEL=

# Ollama (when MODEL_PROVIDER=ollama).
OLLAMA_BASE_URL=http://localhost:11434
# Example: llama3.2 (must be pulled locally).
OLLAMA_MODEL=llama3.2

# AWS Bedrock (when MODEL_PROVIDER=bedrock).
AWS_PROFILE=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=

# Optional Snowflake connector (Sales pipeline / query_snowflake).
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_ROLE=

# Optional external API connector (Account directory / lookup_account).
EXTERNAL_API_BASE_URL=
EXTERNAL_API_KEY=
EXTERNAL_API_TIMEOUT_SECONDS=10

# Local mock connectors — see mock_services/README.md.
# EXTERNAL_API_BASE_URL=http://127.0.0.1:8010
# EXTERNAL_API_KEY=dev-token
# SNOWFLAKE_ACCOUNT=local
# SNOWFLAKE_USER=mock
# SNOWFLAKE_PASSWORD=mock
# SNOWFLAKE_WAREHOUSE=MOCK_WH
# SNOWFLAKE_DATABASE=MOCK_DB
# SNOWFLAKE_SCHEMA=PUBLIC
# SNOWFLAKE_MOCK_URL=http://127.0.0.1:8011

# After each chat turn, optionally write an HTML+JSON review report under
# backend/data/turn_reports/. Disabled by default; set to 1 to enable.
TURN_REPORTS_ENABLED=0
# TURN_REPORTS_DIR=backend/data/turn_reports
